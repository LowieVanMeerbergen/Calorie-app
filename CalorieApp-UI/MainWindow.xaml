<Window x:Class="CalorieApp_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalorieApp_UI"
        mc:Ignorable="d"
        Title="Calorie App" Height="450" Width="800">
    <Grid>
        <ComboBox Name="CmbProductChoice" HorizontalAlignment="Left" Margin="154,164,0,0" VerticalAlignment="Top" Width="160" />
        <TextBox x:Name="TxtWeight" HorizontalAlignment="Left" Margin="154,222,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Label Content="Kies je product:" HorizontalAlignment="Left" Margin="151,133,0,0" VerticalAlignment="Top"/>
        <Label Content="Geef het gegeten gewicht in g:" HorizontalAlignment="Left" Margin="151,191,0,0" VerticalAlignment="Top"/>
        <Button Content="Voeg toe aan de lijst" HorizontalAlignment="Left" Margin="154,247,0,0" VerticalAlignment="Top" Width="120" Click="AddToList"/>
        <Label Content="Dit at je allemaal:" HorizontalAlignment="Left" Margin="438,34,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="LstProducts" Margin="438,65,30,44"/>
        <Label Content="Totale calorieën:" HorizontalAlignment="Left" Margin="269,346,0,0" VerticalAlignment="Top"/>
        <Label x:Name="LblTotalCalories" Content="0 kCal" HorizontalAlignment="Center" Margin="0,346,0,0" VerticalAlignment="Top"/>
    </Grid>
</Window>
