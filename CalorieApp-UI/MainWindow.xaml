<Window x:Class="CalorieApp_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalorieApp_UI"
        mc:Ignorable="d"
        Title="Calorie App" Height="450" Width="800">
    <Grid>
        <ComboBox Name="CmbProductChoice" HorizontalAlignment="Left" Margin="136,96,0,0" VerticalAlignment="Top" Width="160" />
        <TextBox x:Name="TxtWeight" HorizontalAlignment="Left" Margin="136,154,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Label Content="Kies je product:" HorizontalAlignment="Left" Margin="133,65,0,0" VerticalAlignment="Top"/>
        <Label Content="Geef het gegeten gewicht in g:" HorizontalAlignment="Left" Margin="133,123,0,0" VerticalAlignment="Top"/>
        <Button Content="Add to list" HorizontalAlignment="Left" Margin="136,179,0,0" VerticalAlignment="Top" Width="120" Click="AddToList"/>
        <Label Content="Dit at je allemaal:" HorizontalAlignment="Left" Margin="136,230,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="LstProducts" Margin="135,256,400,62"/>
        <Label Content="Totale calorieën:" HorizontalAlignment="Left" Margin="136,377,0,0" VerticalAlignment="Top"/>
        <Label x:Name="LblTotalCalories" Content="0 kCal" HorizontalAlignment="Left" Margin="246,377,0,0" VerticalAlignment="Top"/>
    </Grid>
</Window>
